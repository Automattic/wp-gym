            "arguments_redacted": {
                "post_type": "page",
                "title": "Community Services Overview",
                "content": "<!-- wp:group {\"layout\":{\"type\":\"constrained\"}} -->\n<div class=\"wp-block-group\"><!-- wp:heading -->\n<h2 class=\"wp-block-heading\">Community Services Overview</h2>\n<!-- /wp:heading -->\n\n<!-- wp:paragraph -->\n<p>Our community services are designed to provide practical support, helpful resources, and welcoming points of connection for residents and families. Explore the two core services below to learn how each one helps strengthen daily life in our community.</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:columns {\"className\":\"community-services-overview\"} -->\n<div class=\"wp-block-columns community-services-overview\"><!-- wp:column -->\n<div class=\"wp-block-column\"><!-- wp:heading {\"level\":3} -->\n<h3 class=\"wp-block-heading\">Resident Support</h3>\n<!-- /wp:heading -->\n\n<!-- wp:paragraph -->\n<p>Resident Support connects community members with guidance, referrals, and everyday assistance so they can access the programs, information, and local resources that best fit their needs.</p>\n<!-- /wp:paragraph --></div>\n<!-- /wp:column -->\n\n<!-- wp:column -->\n<div class=\"wp-block-column\"><!-- wp:heading {\"level\":3} -->\n<h3 class=\"wp-block-heading\">Community Engagement</h3>\n<!-- /wp:heading -->\n\n<!-- wp:paragraph -->\n<p>Community Engagement creates opportunities for neighbors to participate, volunteer, attend events, and build relationships that encourage a stronger, more connected local network.</p>\n<!-- /wp:paragraph --></div>\n<!-- /wp:column --></div>\n<!-- /wp:columns --></div>\n<!-- /wp:group -->",
