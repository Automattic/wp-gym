                "post_type": "page",
                "content_format": "blocks",
                "content": "<!-- wp:heading {\"level\":2} -->\n<h2>Summer Cookout Plan</h2>\n<!-- /wp:heading -->\n\n<!-- wp:paragraph -->\n<p>Join your neighbors for a relaxed afternoon cookout in the park. We'll have grills going, cold drinks on ice, and plenty of shaded seating. Bring the whole family \u2014 kids, dogs, and lawn chairs welcome.</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:list -->\n<ul>\n<li>Confirm headcount and assign potluck dishes one week ahead.</li>\n<li>Pick up charcoal, ice, and disposable plates the day before.</li>\n<li>Set up grills, drink coolers, and seating one hour before guests arrive.</li>\n</ul>\n<!-- /wp:list -->\n\n<!-- wp:buttons -->\n<div class=\"wp-block-buttons\">\n<!-- wp:button -->\n<div class=\"wp-block-button\"><a class=\"wp-block-button__link wp-element-button\" href=\"#menu\">View menu</a></div>\n<!-- /wp:button -->\n</div>\n<!-- /wp:buttons -->"
            }
        }
