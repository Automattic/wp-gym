{
  "schema_version": 1,
  "id": "modern-wordpress-api-abilities-site-summary",
  "label": "Provider-friendly site summary ability",
  "issue": "https://github.com/Automattic/wp-gym/issues/3",
  "split": {
    "membership": "public",
    "variant_family": "modern-wordpress-api-site-summary",
    "variant_seed": "abilities-site-summary-public-v1",
    "parent_scenario_id": null,
    "artifact_policy": {
      "public_artifacts": ["prompt", "scenario_manifest", "grader", "starter_workspace"],
      "private_artifacts": ["held_out_prompt", "held_out_manifest", "held_out_grader", "held_out_workspace_fixture"],
      "grader_exposure": "full_public"
    }
  },
  "prompt_file": "../../prompts/modern-wordpress-api/abilities-site-summary.md",
  "grader_file": "../../graders/modern-wordpress-api/abilities-site-summary.php",
  "tags": ["wordpress", "abilities-api", "modern-api"],
  "rules": {
    "general": ["wordpress_docs_standards", "no_speculative_plugin_packaging", "supported_plugin_author_metadata"],
    "task_specific": ["abilities_api_lifecycle", "ability_registered", "exact_output_shape"]
  },
  "limits": {
    "max_turns": 25,
    "step_budget": 12,
    "time_budget_ms": 600000
  },
  "environment": {
    "action_mode": "workspace",
    "uses_workspace": true,
    "reset_fixture": "wordpress-playground-clean-site",
    "observation_channels": ["prompt", "workspace_tree", "wordpress_runtime"],
    "allowed_tools": [
      "workspace_show",
      "workspace_ls",
      "workspace_read",
      "workspace_grep",
      "workspace_write",
      "workspace_edit",
      "workspace_apply_patch",
      "workspace_git_status",
      "wordpress_runtime_ls",
      "run_wp_cli"
    ],
    "writable_roots": ["plugins/"],
    "hidden_paths": ["graders/", "scenarios/", "prompts/", "checks/", "task-sets/", ".github/", "docs/", "scripts/"],
    "workspace_template": "starter-workspaces/modern-wordpress-api",
    "completion_policy": {
      "type": "explicit_final_response"
    },
    "termination_policy": {
      "type": "terminal_grader"
    },
    "truncation_policy": {
      "type": "budget",
      "max_turns": 25,
      "step_budget": 12,
      "time_budget_ms": 600000
    }
  },
  "reward_spec": {
    "type": "terminal_php_grader",
    "success_threshold": 1,
    "reward_range": [0, 1]
  },
  "calibration": {
    "status": "pilot",
    "benchmark_scope": "pilot",
    "difficulty_band": "uncalibrated",
    "headline_score_eligible": false,
    "baseline_result_sets": [],
    "known_shortcuts": ["source_string_lifecycle_spoof", "hard_coded_clean_site_state"],
    "task_contract_level": "workspace_diff_diagnostic",
    "benchmark_blockers": ["workspace_diff_diagnostic_only", "missing_baseline_results", "uncalibrated_difficulty"]
  },
  "expected_artifacts": ["workspace_diff", "plugin_files", "grader_result"],
  "expected": {
    "ability": "site-tools/site-summary",
    "category": "site-tools",
    "required_output_keys": ["site_name", "post_count"]
  }
}
