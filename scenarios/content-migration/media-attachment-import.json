{
  "schema_version": 1,
  "id": "content-migration-media-attachment-import",
  "label": "Import content with local media attachments",
  "issue": "https://github.com/Automattic/wp-gym/issues/83",
  "prompt_file": "../../prompts/content-migration/media-attachment-import.md",
  "grader_file": "../../graders/content-migration/media-attachment-import.php",
  "tags": ["wordpress", "content-migration", "media-import", "attachments"],
  "rules": {
    "general": ["wordpress_editable_blocks", "no_raw_html_or_shortcodes"],
    "task_specific": ["source_content_imported", "attachment_posts_created", "attachment_files_local", "featured_image_restored", "no_stale_remote_media_urls"]
  },
  "limits": {
    "max_turns": 18,
    "step_budget": 16,
    "time_budget_ms": 900000
  },
  "environment": {
    "action_mode": "workspace",
    "uses_workspace": true,
    "reset_fixture": "wordpress-playground-clean-site",
    "observation_channels": ["prompt", "workspace_tree", "wordpress_runtime", "rendered_site"],
    "allowed_tools": [
      "workspace_show",
      "workspace_ls",
      "workspace_read",
      "workspace_grep",
      "workspace_write",
      "workspace_edit",
      "workspace_apply_patch",
      "workspace_git_status",
      "wordpress_runtime_ls",
      "run_wp_cli"
    ],
    "writable_roots": ["plugins/"],
    "hidden_paths": ["graders/", "scenarios/", "prompts/", "checks/", "task-sets/", ".github/", "docs/", "scripts/"],
    "workspace_template": "starter-workspaces/content-migration-media-import",
    "completion_policy": {
      "type": "explicit_final_response"
    },
    "termination_policy": {
      "type": "terminal_grader"
    },
    "truncation_policy": {
      "type": "budget",
      "max_turns": 18,
      "step_budget": 16,
      "time_budget_ms": 900000
    }
  },
  "reward_spec": {
    "type": "terminal_php_grader",
    "success_threshold": 1,
    "reward_range": [0, 1]
  },
  "calibration": {
    "status": "pilot",
    "benchmark_scope": "pilot",
    "difficulty_band": "uncalibrated",
    "headline_score_eligible": false,
    "baseline_result_sets": [],
    "known_shortcuts": ["text_only_import_without_media", "remote_url_reuse"],
    "task_contract_level": "workspace_diff_diagnostic",
    "benchmark_blockers": ["workspace_diff_diagnostic_only", "missing_baseline_results", "uncalibrated_difficulty", "known_reward_shortcut"]
  },
  "expected_artifacts": ["workspace_diff", "wordpress_state", "media_library", "grader_result"],
  "expected": {
    "source_package": "starter-workspaces/content-migration-media-import/import-package",
    "required_content_titles": ["Harbor Market Spring Menu", "Catering Gallery"],
    "required_attachments": ["harbor-market-hero.svg", "catering-board.svg"],
    "featured_image_post": "Harbor Market Spring Menu",
    "forbidden_media_hosts": ["legacy.example.test", "old-harbor-market.invalid"]
  }
}
