{
  "id": "first-live-run",
  "label": "First live side-by-side task set",
  "issue": "https://github.com/Automattic/wp-gym/issues/18",
  "description": "A small, stable set of WordPress tasks for the first live side-by-side run.",
  "benchmark_status": "pilot",
  "benchmark": false,
  "headline_score_eligible": false,
  "aggregate_score": false,
  "score_scope": "pilot",
  "task_contract_level": "mixed_diagnostic",
  "split_policy": {
    "lane": "public",
    "allowed_splits": ["public", "calibration"],
    "requires_held_out_private": false,
    "contamination_controls": ["public_tasks_are_training_visible", "headline_scores_blocked_until_held_out_private_ready"]
  },
  "benchmark_blockers": [
    "pilot_task_set",
    "uncalibrated_difficulty",
    "missing_baseline_results",
    "diagnostic_contract_only"
  ],
  "scenario_manifests": [
    "../scenarios/site-building/community-garden.json",
    "../scenarios/block-markup/no-fallback-pricing-section.json",
    "../scenarios/modern-wordpress-api/abilities-site-summary.json"
  ],
  "tasks": [
    {
      "scenario_id": "site-building-community-garden",
      "role": "site-building",
      "summary": "Build a welcoming Marshside Community Garden site with core visitor information."
    },
    {
      "scenario_id": "block-markup-no-fallback-pricing-section",
      "role": "editable-page-layout",
      "summary": "Create an editable pricing page with a structured three-plan layout."
    },
    {
      "scenario_id": "modern-wordpress-api-abilities-site-summary",
      "role": "developer-api-tooling",
      "summary": "Expose a small site summary automation surface through the Abilities API."
    }
  ]
}
