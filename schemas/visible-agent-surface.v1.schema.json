{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Automattic/wp-gym/main/schemas/visible-agent-surface.v1.schema.json",
  "title": "Visible agent surface artifact",
  "description": "Benchmark-side contract for the prompt/tool/workspace surface artifact produced by the generic Homeboy Extensions runner. Producer implementation is tracked in https://github.com/Extra-Chill/homeboy-extensions/issues/842.",
  "type": "object",
  "required": ["schema_version", "artifact", "run", "instructions", "tools", "workspace", "audit", "recommendation"],
  "properties": {
    "schema_version": { "const": 1 },
    "artifact": {
      "type": "object",
      "required": ["name", "wp_gym_issue", "producer_issue", "generated_at"],
      "properties": {
        "name": { "const": "visible-agent-surface" },
        "wp_gym_issue": { "const": "https://github.com/Automattic/wp-gym/issues/22" },
        "producer_issue": { "const": "https://github.com/Extra-Chill/homeboy-extensions/issues/842" },
        "generated_at": { "type": "string", "format": "date-time" },
        "redaction_status": { "enum": ["redacted", "hash_only", "no_sensitive_values_observed"] }
      },
      "additionalProperties": true
    },
    "run": {
      "type": "object",
      "required": ["scenario_id", "task_set_id", "runner", "provider", "model"],
      "properties": {
        "scenario_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "task_set_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "runner": { "type": "string", "minLength": 1 },
        "provider": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "instructions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/surface_item" }
    },
    "tools": {
      "type": "array",
      "items": {
        "allOf": [
          { "$ref": "#/$defs/surface_item" },
          {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "input_schema_sha256": { "$ref": "#/$defs/sha256_or_null" }
            }
          }
        ]
      }
    },
    "workspace": {
      "type": "object",
      "required": ["uses_workspace", "allowed_tools", "writable_roots", "hidden_paths"],
      "properties": {
        "uses_workspace": { "type": "boolean" },
        "allowed_tools": { "type": "array", "items": { "type": "string", "pattern": "^[a-z0-9_]+$" } },
        "writable_roots": { "type": "array", "items": { "type": "string" } },
        "hidden_paths": { "type": "array", "items": { "type": "string" } },
        "dirty_state_visible": { "type": ["boolean", "null"] },
        "workspace_ref_sha256": { "$ref": "#/$defs/sha256_or_null" }
      },
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": ["classification_counts", "interference_findings", "hidden_evidence_boundaries"],
      "properties": {
        "classification_counts": {
          "type": "object",
          "required": ["acceptable_scaffolding", "task_sandbox_interference", "unknown"],
          "properties": {
            "acceptable_scaffolding": { "type": "integer", "minimum": 0 },
            "task_sandbox_interference": { "type": "integer", "minimum": 0 },
            "unknown": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": true
        },
        "interference_findings": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9_]+$" }
        },
        "hidden_evidence_boundaries": {
          "type": "object",
          "required": ["covered_evidence_kinds", "surfaces", "benchmark_mode_eligible", "accepted_exposures"],
          "properties": {
            "covered_evidence_kinds": {
              "type": "array",
              "items": {
                "enum": ["hidden_grader", "held_out_variant", "private_fixture", "expected_answer", "task_policy_internal"]
              }
            },
            "surfaces": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name", "status", "findings"],
                "properties": {
                  "name": { "enum": ["prompt", "tools", "workspace", "artifacts", "report_body"] },
                  "status": { "enum": ["pass", "fail", "not_observed"] },
                  "findings": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["kind", "exposed", "message"],
                      "properties": {
                        "kind": { "type": "string", "minLength": 1 },
                        "exposed": { "type": "boolean" },
                        "message": { "type": "string", "minLength": 1 },
                        "severity": { "enum": ["info", "warning", "error"] }
                      },
                      "additionalProperties": true
                    }
                  }
                },
                "additionalProperties": true
              }
            },
            "benchmark_mode_eligible": { "type": "boolean" },
            "accepted_exposures": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["kind", "scope", "reason"],
                "properties": {
                  "kind": { "type": "string", "minLength": 1 },
                  "scope": { "enum": ["pilot_only", "non_benchmark"] },
                  "reason": { "type": "string", "minLength": 1 }
                },
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "recommendation": {
      "type": "object",
      "required": ["minimal_live_run_config", "producer_status"],
      "properties": {
        "minimal_live_run_config": { "type": "array", "items": { "type": "string", "pattern": "^[a-z0-9_]+$" } },
        "producer_status": { "enum": ["fixture_contract_only", "producer_artifact_available"] },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "surface_item": {
      "type": "object",
      "required": ["id", "source", "sha256", "classification"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*$" },
        "source": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" },
        "excerpt": { "type": ["string", "null"] },
        "classification": { "enum": ["acceptable_scaffolding", "task_sandbox_interference", "unknown"] },
        "classification_note": { "type": "string" },
        "redaction_status": { "enum": ["redacted", "hash_only", "no_sensitive_values_observed"] }
      },
      "additionalProperties": true
    },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "sha256_or_null": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" }
  },
  "additionalProperties": true
}
