{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Automattic/wp-gym/main/schemas/action.v1.schema.json",
  "title": "WP Gym Action v1",
  "description": "Canonical action record for one requested episode step. See https://github.com/Automattic/wp-gym/issues/80.",
  "oneOf": [
    { "$ref": "#/$defs/wpCliAction" },
    { "$ref": "#/$defs/filesystemAction" },
    { "$ref": "#/$defs/restAction" },
    { "$ref": "#/$defs/browserAction" }
  ],
  "$defs": {
    "metadata": {
      "type": "object",
      "description": "Action routing/debug metadata. Reward and success values do not belong here.",
      "propertyNames": { "not": { "enum": ["reward", "success", "score"] } },
      "additionalProperties": true
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+"
    },
    "wpCliAction": {
      "type": "object",
      "required": ["schema_version", "type", "command"],
      "properties": {
        "schema_version": { "const": 1 },
        "type": { "const": "wp_cli" },
        "id": { "type": "string", "minLength": 1 },
        "metadata": { "$ref": "#/$defs/metadata" },
        "command": {
          "type": "string",
          "pattern": "^(?!\\s*wp(?:\\s|$))[\\s\\S]*\\S[\\s\\S]*$",
          "description": "WP-CLI command without the leading `wp`, for example `post list --post_type=page --format=json`."
        },
        "timeout_ms": { "type": "integer", "minimum": 1 },
        "cwd": { "$ref": "#/$defs/relativePath" },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "filesystemAction": {
      "type": "object",
      "required": ["schema_version", "type", "operation", "path"],
      "properties": {
        "schema_version": { "const": 1 },
        "type": { "const": "filesystem" },
        "id": { "type": "string", "minLength": 1 },
        "metadata": { "$ref": "#/$defs/metadata" },
        "operation": { "enum": ["read", "write", "list", "delete"] },
        "path": { "$ref": "#/$defs/relativePath" },
        "content": { "type": "string" }
      },
      "allOf": [
        {
          "if": { "properties": { "operation": { "const": "write" } }, "required": ["operation"] },
          "then": { "required": ["content"] }
        },
        {
          "if": { "properties": { "operation": { "enum": ["read", "list", "delete"] } }, "required": ["operation"] },
          "then": { "not": { "required": ["content"] } }
        }
      ],
      "additionalProperties": false
    },
    "restAction": {
      "type": "object",
      "required": ["schema_version", "type", "method", "path"],
      "properties": {
        "schema_version": { "const": 1 },
        "type": { "const": "rest" },
        "id": { "type": "string", "minLength": 1 },
        "metadata": { "$ref": "#/$defs/metadata" },
        "method": { "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
        "path": {
          "type": "string",
          "pattern": "^/",
          "description": "Sandbox-relative REST path, for example `/wp-json/wp/v2/posts`."
        },
        "body": true,
        "headers": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "timeout_ms": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "browserAction": {
      "type": "object",
      "required": ["schema_version", "type", "operation", "replayability"],
      "properties": {
        "schema_version": { "const": 1 },
        "type": { "const": "browser" },
        "id": { "type": "string", "minLength": 1 },
        "metadata": { "$ref": "#/$defs/metadata" },
        "operation": { "enum": ["navigate", "click", "fill", "press", "capture"] },
        "replayability": { "enum": ["replayable", "evidence_only"] },
        "selector": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "minLength": 1 },
        "value": true,
        "wait_for": { "type": "string", "minLength": 1 },
        "capture": {
          "type": "array",
          "items": { "enum": ["html", "screenshot", "console", "network"] },
          "uniqueItems": true
        },
        "timeout_ms": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    }
  }
}
