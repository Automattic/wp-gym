{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Automattic/wp-gym/main/schemas/observation.v1.schema.json",
  "title": "WP Gym Observation v1",
  "description": "Canonical observation record for replayable episode evidence. See https://github.com/Automattic/wp-gym/issues/80.",
  "oneOf": [
    { "$ref": "#/$defs/commandResultObservation" },
    { "$ref": "#/$defs/logsObservation" },
    { "$ref": "#/$defs/wpStateObservation" },
    { "$ref": "#/$defs/filesObservation" },
    { "$ref": "#/$defs/restResponseObservation" },
    { "$ref": "#/$defs/htmlObservation" },
    { "$ref": "#/$defs/screenshotObservation" },
    { "$ref": "#/$defs/browserResultObservation" },
    { "$ref": "#/$defs/editorResultObservation" }
  ],
  "$defs": {
    "metadata": {
      "type": "object",
      "description": "Runtime/debug metadata. Reward and success values do not belong here.",
      "propertyNames": { "not": { "enum": ["reward", "success", "score"] } },
      "additionalProperties": true
    },
    "error": {
      "type": ["object", "null"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 }
      },
      "required": ["code", "message"],
      "additionalProperties": false
    },
    "artifactRef": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "mime_type": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "viewport": {
      "type": "object",
      "required": ["width", "height"],
      "properties": {
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "device_scale_factor": { "type": "number", "exclusiveMinimum": 0 },
        "is_mobile": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "stateSnapshot": {
      "type": "object",
      "properties": {
        "url": { "type": "string", "minLength": 1 },
        "title": { "type": "string" },
        "selector_text": { "type": "string" },
        "post_id": { "type": "integer", "minimum": 1 },
        "post_type": { "type": "string", "minLength": 1 },
        "post_status": { "type": "string", "minLength": 1 },
        "selected_block_client_id": { "type": "string", "minLength": 1 },
        "block_count": { "type": "integer", "minimum": 0 },
        "dirty": { "type": "boolean" },
        "mode": { "enum": ["visual", "code"] }
      },
      "additionalProperties": false
    },
    "browserMetrics": {
      "type": "object",
      "required": ["schema", "hasBrowserMetrics", "metrics", "artifacts"],
      "properties": {
        "schema": { "const": "wp-codebox/browser-metrics/v1" },
        "hasBrowserMetrics": { "type": "boolean" },
        "metrics": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        },
        "artifacts": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["path", "kind"],
            "properties": {
              "path": { "type": "string", "minLength": 1 },
              "kind": { "enum": ["json", "jsonl"] }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "commandResultObservation": {
      "type": "object",
      "required": ["schema_version", "type", "action_type", "command", "status", "stdout", "stderr", "timed_out", "error"],
      "properties": {
        "schema_version": { "const": 1 },
        "type": { "const": "command_result" },
        "id": { "type": "string", "minLength": 1 },
        "metadata": { "$ref": "#/$defs/metadata" },
        "action_type": { "const": "wp_cli" },
        "command": { "type": "string", "minLength": 1 },
        "status": { "type": ["integer", "null"] },
        "stdout": { "type": "string" },
        "stderr": { "type": "string" },
        "timeout_ms": { "type": "integer", "minimum": 1 },
        "timed_out": { "type": "boolean" },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "error": { "$ref": "#/$defs/error" }
      },
      "additionalProperties": false
    },
    "logsObservation": {
      "type": "object",
      "required": ["schema_version", "type", "entries"],
      "properties": {
        "schema_version": { "const": 1 },
        "type": { "const": "logs" },
        "id": { "type": "string", "minLength": 1 },
        "metadata": { "$ref": "#/$defs/metadata" },
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["message"],
            "properties": {
              "timestamp": { "type": "string", "format": "date-time" },
              "level": { "type": "string", "minLength": 1 },
              "message": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "wpStateObservation": {
      "type": "object",
      "required": ["schema_version", "type", "state"],
      "properties": {
        "schema_version": { "const": 1 },
        "type": { "const": "wp_state" },
        "id": { "type": "string", "minLength": 1 },
        "metadata": { "$ref": "#/$defs/metadata" },
        "state": { "type": "object", "additionalProperties": true }
      },
      "additionalProperties": false
    },
    "filesObservation": {
      "type": "object",
      "required": ["schema_version", "type", "action_type", "operation", "files"],
      "properties": {
        "schema_version": { "const": 1 },
        "type": { "const": "files" },
        "id": { "type": "string", "minLength": 1 },
        "metadata": { "$ref": "#/$defs/metadata" },
        "action_type": { "const": "filesystem" },
        "operation": { "enum": ["read", "write", "list", "delete"] },
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path"],
            "properties": {
              "path": { "type": "string", "minLength": 1 },
              "kind": { "enum": ["file", "directory", "unknown"] },
              "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "content": { "type": "string" },
              "size_bytes": { "type": "integer", "minimum": 0 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "restResponseObservation": {
      "type": "object",
      "required": ["schema_version", "type", "action_type", "method", "path", "status", "headers", "body", "timed_out", "error"],
      "properties": {
        "schema_version": { "const": 1 },
        "type": { "const": "rest_response" },
        "id": { "type": "string", "minLength": 1 },
        "metadata": { "$ref": "#/$defs/metadata" },
        "action_type": { "const": "rest" },
        "method": { "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
        "path": { "type": "string", "pattern": "^/" },
        "status": { "type": ["integer", "null"] },
        "headers": { "type": "object", "additionalProperties": { "type": "string" } },
        "body": true,
        "timeout_ms": { "type": "integer", "minimum": 1 },
        "timed_out": { "type": "boolean" },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "error": { "$ref": "#/$defs/error" }
      },
      "additionalProperties": false
    },
    "htmlObservation": {
      "type": "object",
      "required": ["schema_version", "type", "html"],
      "properties": {
        "schema_version": { "const": 1 },
        "type": { "const": "html" },
        "id": { "type": "string", "minLength": 1 },
        "metadata": { "$ref": "#/$defs/metadata" },
        "action_type": { "enum": ["browser", "rest"] },
        "url": { "type": "string", "minLength": 1 },
        "html": { "type": "string" }
      },
      "additionalProperties": false
    },
    "screenshotObservation": {
      "type": "object",
      "required": ["schema_version", "type", "mime_type"],
      "properties": {
        "schema_version": { "const": 1 },
        "type": { "const": "screenshot" },
        "id": { "type": "string", "minLength": 1 },
        "metadata": { "$ref": "#/$defs/metadata" },
        "action_type": { "const": "browser" },
        "mime_type": { "enum": ["image/png", "image/jpeg"] },
        "artifact_path": { "type": "string", "minLength": 1 },
        "data_base64": { "type": "string", "minLength": 1 }
      },
      "oneOf": [
        { "required": ["artifact_path"] },
        { "required": ["data_base64"] }
      ],
      "additionalProperties": false
    },
    "browserResultObservation": {
      "type": "object",
      "required": ["schema_version", "type", "action_type", "operation", "replayability", "artifacts", "error"],
      "properties": {
        "schema_version": { "const": 1 },
        "type": { "const": "browser_result" },
        "id": { "type": "string", "minLength": 1 },
        "metadata": { "$ref": "#/$defs/metadata" },
        "action_type": { "const": "browser" },
        "operation": { "enum": ["navigate", "click", "fill", "press", "capture"] },
        "replayability": { "enum": ["replayable", "evidence_only"] },
        "url": { "type": "string", "minLength": 1 },
        "selector": { "type": "string", "minLength": 1 },
        "viewport": { "$ref": "#/$defs/viewport" },
        "state": { "$ref": "#/$defs/stateSnapshot" },
        "artifacts": {
          "type": "array",
          "items": { "$ref": "#/$defs/artifactRef" }
        },
        "browser_metrics": { "$ref": "#/$defs/browserMetrics" },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "error": { "$ref": "#/$defs/error" }
      },
      "additionalProperties": false
    },
    "editorResultObservation": {
      "type": "object",
      "required": ["schema_version", "type", "action_type", "operation", "replayability", "state", "artifacts", "error"],
      "properties": {
        "schema_version": { "const": 1 },
        "type": { "const": "editor_result" },
        "id": { "type": "string", "minLength": 1 },
        "metadata": { "$ref": "#/$defs/metadata" },
        "action_type": { "const": "editor" },
        "operation": { "enum": ["open_post", "insert_block", "update_block", "select_block", "save_post", "publish_post", "switch_mode", "inspect_state"] },
        "replayability": { "enum": ["replayable", "evidence_only"] },
        "state": { "$ref": "#/$defs/stateSnapshot" },
        "artifacts": {
          "type": "array",
          "items": { "$ref": "#/$defs/artifactRef" }
        },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "error": { "$ref": "#/$defs/error" }
      },
      "additionalProperties": false
    }
  }
}
