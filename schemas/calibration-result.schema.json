{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Automattic/wp-gym/main/schemas/calibration-result.schema.json",
  "title": "WP Gym calibration result set",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "scenario_id",
    "task_set_id",
    "created_at",
    "rows",
    "summary"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*$" },
    "scenario_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "task_set_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "created_at": { "type": "string", "format": "date-time" },
    "source": {
      "type": "object",
      "properties": {
        "issue": { "type": "string" },
        "workflow_run_url": { "type": "string" },
        "artifact_url": { "type": "string" }
      },
      "additionalProperties": true
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["row_type", "label", "attempts", "passes", "pass_rate"],
        "properties": {
          "row_type": {
            "enum": [
              "no_op",
              "heuristic_scripted",
              "cheap_model",
              "frontier_model",
              "repeated_attempts",
              "human_reference"
            ]
          },
          "model_tier": {
            "enum": [
              "no_op",
              "heuristic_scripted",
              "cheap_model",
              "frontier_model",
              "human_reference"
            ]
          },
          "label": { "type": "string", "minLength": 1 },
          "provider": { "type": "string" },
          "model": { "type": "string" },
          "result_set_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*$" },
          "attempt_ids": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "pass_at_1": { "type": "number", "minimum": 0, "maximum": 1 },
          "pass_at_n": { "type": "number", "minimum": 0, "maximum": 1 },
          "attempts": { "type": "integer", "minimum": 1 },
          "passes": { "type": "integer", "minimum": 0 },
          "pass_rate": { "type": "number", "minimum": 0, "maximum": 1 },
          "mean_reward": { "type": "number", "minimum": 0, "maximum": 1 },
          "reward_variance": { "type": "number", "minimum": 0 },
          "reward_stddev": { "type": "number", "minimum": 0 },
          "confidence_interval_95": {
            "type": "array",
            "prefixItems": [
              { "type": "number", "minimum": 0, "maximum": 1 },
              { "type": "number", "minimum": 0, "maximum": 1 }
            ],
            "minItems": 2,
            "maxItems": 2
          },
          "notes": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "pass_rate_band",
        "confidence_interval_95",
        "held_out_private_variants_ready",
        "promotion_recommendation"
      ],
      "properties": {
        "pass_rate_band": { "enum": ["uncalibrated", "too_easy", "easy", "target", "hard", "too_hard"] },
        "confidence_interval_95": {
          "type": "array",
          "prefixItems": [
            { "type": "number", "minimum": 0, "maximum": 1 },
            { "type": "number", "minimum": 0, "maximum": 1 }
          ],
          "minItems": 2,
          "maxItems": 2
        },
        "held_out_private_variants_ready": { "type": "boolean" },
        "promotion_recommendation": { "enum": ["keep_pilot", "calibrating", "benchmark_ready", "exclude"] },
        "blockers": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9_]+$" }
        },
        "large_n_distribution": {
          "type": "object",
          "required": ["min_attempts_per_model_tier", "stable_result_sets", "benchmark_ready_threshold_met", "model_tiers"],
          "properties": {
            "min_attempts_per_model_tier": { "type": "integer", "minimum": 2 },
            "stable_result_sets": { "type": "boolean" },
            "benchmark_ready_threshold_met": { "type": "boolean" },
            "model_tiers": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "required": ["attempts", "passes", "pass_rate", "confidence_interval_95"],
                "properties": {
                  "attempts": { "type": "integer", "minimum": 1 },
                  "passes": { "type": "integer", "minimum": 0 },
                  "pass_rate": { "type": "number", "minimum": 0, "maximum": 1 },
                  "reward_variance": { "type": "number", "minimum": 0 },
                  "confidence_interval_95": {
                    "type": "array",
                    "prefixItems": [
                      { "type": "number", "minimum": 0, "maximum": 1 },
                      { "type": "number", "minimum": 0, "maximum": 1 }
                    ],
                    "minItems": 2,
                    "maxItems": 2
                  },
                  "failure_classes": {
                    "type": "object",
                    "additionalProperties": { "type": "integer", "minimum": 0 }
                  }
                },
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
