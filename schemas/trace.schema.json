{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Automattic/wp-gym/main/schemas/trace.schema.json",
  "title": "WP Gym trace",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["timestamp", "action", "observation", "reward", "done", "info"],
    "properties": {
      "timestamp": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T" },
      "action": { "$ref": "action.schema.json" },
      "observation": { "$ref": "observation.schema.json" },
      "reward": { "type": ["number", "null"] },
      "done": { "type": "boolean" },
      "info": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "additionalProperties": false
  }
}
