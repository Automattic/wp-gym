{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Automattic/wp-gym/main/schemas/run-registry-entry.v1.schema.json",
  "title": "WP Gym durable run registry entry",
  "description": "Versioned wp-gym record that makes completed eval runs discoverable across labs and execution substrates.",
  "type": "object",
  "required": [
    "schema_version",
    "registry",
    "run",
    "task_set",
    "scenario",
    "runner",
    "runtime",
    "grade_identity",
    "calibration",
    "benchmark",
    "eval_artifact",
    "artifact_index"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "registry": {
      "type": "object",
      "required": ["name", "issue", "created_at"],
      "properties": {
        "name": { "const": "wp-gym-run-registry" },
        "issue": { "const": "https://github.com/Automattic/wp-gym/issues/136" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": true
    },
    "run": {
      "type": "object",
      "required": ["id", "actor", "completed_at", "outcome"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "actor": { "type": "string", "minLength": 1 },
        "attempt": { "type": "integer", "minimum": 1 },
        "attempt_id": { "type": ["string", "null"], "minLength": 1 },
        "attempt_count": { "type": "integer", "minimum": 1 },
        "result_set_id": { "type": ["string", "null"], "pattern": "^[a-z0-9][a-z0-9_.-]*$" },
        "seed": { "type": ["string", "null"] },
        "temperature": { "type": ["string", "number", "null"] },
        "started_at": { "type": ["string", "null"], "format": "date-time" },
        "completed_at": { "type": "string", "format": "date-time" },
        "outcome": { "enum": ["passed", "failed", "errored"] }
      },
      "additionalProperties": true
    },
    "task_set": {
      "type": "object",
      "required": ["id", "version", "sha256", "source_path", "benchmark_status", "headline_score_eligible", "compatibility_group"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "version": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" },
        "source_path": { "type": "string", "minLength": 1 },
        "benchmark_status": { "enum": ["pilot", "calibrating", "benchmark_ready", "excluded"] },
        "headline_score_eligible": { "type": "boolean" },
        "compatibility_group": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*$" }
      },
      "additionalProperties": true
    },
    "scenario": {
      "type": "object",
      "required": ["id", "version", "sha256", "source_path", "prompt_sha256", "task_family"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "version": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" },
        "source_path": { "type": "string", "minLength": 1 },
        "prompt_sha256": { "$ref": "#/$defs/sha256" },
        "task_family": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "capabilities": {
          "type": ["object", "null"],
          "properties": {
            "schema_version": { "const": 1 },
            "primary": { "type": "string", "pattern": "^[a-z0-9_]+$" },
            "secondary": { "type": "array", "items": { "type": "string", "pattern": "^[a-z0-9_]+$" } },
            "criteria": { "type": "array", "items": { "type": "string", "pattern": "^[a-z0-9_]+$" } }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "runner": {
      "type": "object",
      "required": ["provider", "model"],
      "properties": {
        "provider": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "agent_slug": { "type": ["string", "null"] },
        "workflow_run_url": { "type": ["string", "null"] },
        "job_id": { "type": ["string", "integer", "null"] },
        "tool_policy_sha256": { "anyOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }] }
      },
      "additionalProperties": true
    },
    "runtime": {
      "type": "object",
      "required": ["id", "artifact_bundle_id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "environment_id": { "type": ["string", "null"] },
        "artifact_bundle_id": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "grade_identity": {
      "type": "object",
      "required": ["grader_sha256", "result_sha256", "success", "reward", "failure_class"],
      "properties": {
        "grader_sha256": { "$ref": "#/$defs/sha256" },
        "result_sha256": { "$ref": "#/$defs/sha256" },
        "success": { "type": "boolean" },
        "reward": { "type": "number" },
        "failure_class": { "enum": ["none", "runtime_failure", "agent_failure", "grader_failure", "task_failure"] }
      },
      "additionalProperties": true
    },
    "calibration": {
      "type": "object",
      "required": ["row_type", "included", "status"],
      "properties": {
        "row_type": {
          "enum": ["no_op", "heuristic_scripted", "cheap_model", "frontier_model", "repeated_attempts", "human_reference", "excluded"]
        },
        "model_tier": {
          "enum": ["no_op", "heuristic_scripted", "cheap_model", "frontier_model", "human_reference", "excluded"]
        },
        "included": { "type": "boolean" },
        "status": { "enum": ["pilot", "calibrating", "benchmark_ready", "excluded"] },
        "result_set_id": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "benchmark": {
      "type": "object",
      "required": ["eligible", "headline_score_eligible", "compatibility_group"],
      "properties": {
        "eligible": { "type": "boolean" },
        "headline_score_eligible": { "type": "boolean" },
        "compatibility_group": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*$" },
        "release_id": { "type": "string", "minLength": 1 },
        "release_version": { "type": "string", "minLength": 1 },
        "release_type": { "enum": ["pilot", "calibration", "headline"] },
        "release_status": { "enum": ["pilot", "calibrating", "benchmark_ready", "deprecated", "retired"] },
        "release_manifest": { "type": "string", "minLength": 1 },
        "release_manifest_sha256": { "$ref": "#/$defs/sha256" },
        "exclusion_reasons": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9_]+$" }
        }
      },
      "additionalProperties": true
    },
    "provenance": {
      "type": ["object", "null"],
      "description": "Immutable benchmark execution provenance. Required by benchmark-mode validation.",
      "additionalProperties": true
    },
    "eval_artifact": { "$ref": "#/$defs/artifact_reference" },
    "artifact_index": {
      "type": "object",
      "required": ["schema_version", "index_id", "created_at", "entries"],
      "properties": {
        "schema_version": { "const": 1 },
        "index_id": { "type": "string", "minLength": 1 },
        "created_at": { "type": "string", "format": "date-time" },
        "entries": {
          "type": "array",
          "minItems": 1,
          "items": {
            "allOf": [
              { "$ref": "#/$defs/artifact_reference" },
              {
                "type": "object",
                "required": ["name", "category", "required"],
                "properties": {
                  "name": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*$" },
                  "category": {
                    "enum": ["eval_artifact", "grade", "replay", "transcript", "rendered_output", "screenshot", "log", "artifact_index", "runtime_bundle"]
                  },
                  "required": { "type": "boolean" }
                }
              }
            ]
          }
        }
      },
      "additionalProperties": true
    },
    "held_out": {
      "type": "object",
      "required": ["pack_id", "pack_version", "entry_id", "scenario_id", "split_membership", "sealed_hashes"],
      "properties": {
        "pack_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "pack_version": { "type": "string", "minLength": 1 },
        "public_reference": { "type": ["string", "null"] },
        "compatibility_group": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "entry_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "scenario_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "parent_scenario_id": { "type": ["string", "null"], "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "variant_family": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "variant_seed": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*$" },
        "split_membership": { "const": "held_out_private" },
        "public_report_policy": { "enum": ["aggregate_only", "aggregate_plus_hashes"] },
        "sealed_hashes": {
          "type": "object",
          "required": ["scenario_manifest", "prompt", "grader", "setup", "expected_artifacts", "replay_contract"],
          "properties": {
            "scenario_manifest": { "$ref": "#/$defs/sha256" },
            "prompt": { "$ref": "#/$defs/sha256" },
            "grader": { "$ref": "#/$defs/sha256" },
            "setup": { "$ref": "#/$defs/sha256" },
            "expected_artifacts": { "$ref": "#/$defs/sha256" },
            "replay_contract": { "$ref": "#/$defs/sha256" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "artifact_reference": {
      "type": "object",
      "required": ["kind", "path_or_url", "sha256"],
      "properties": {
        "kind": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "path_or_url": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" },
        "media_type": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  },
  "additionalProperties": true
}
