{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Automattic/wp-gym/main/schemas/scenario.schema.json",
  "title": "WP Gym scenario manifest",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "label",
    "split",
    "prompt_file",
    "grader_file",
    "rules",
    "capabilities",
    "environment",
    "reward_spec",
    "calibration",
    "expected_artifacts",
    "episode_contract"
  ],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "label": { "type": "string", "minLength": 1 },
    "split": {
      "type": "object",
      "description": "Public/calibration/validation/held-out split and variant-lineage metadata. Private task contents stay out of public manifests.",
      "required": ["membership", "variant_family", "variant_seed", "artifact_policy"],
      "properties": {
        "membership": { "enum": ["public", "calibration", "validation", "held_out_private"] },
        "variant_family": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "variant_seed": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*$" },
        "parent_scenario_id": { "type": ["string", "null"], "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "lineage_note": { "type": "string" },
        "held_out_private_variant": {
          "type": "object",
          "description": "Non-sensitive pointer describing that a private variant exists or is planned without exposing prompt, fixture, or grader contents.",
          "properties": {
            "status": { "enum": ["planned", "ready", "not_applicable"] },
            "reference": { "type": "string" },
            "notes": { "type": "string" }
          },
          "additionalProperties": true
        },
        "artifact_policy": {
          "type": "object",
          "required": ["public_artifacts", "private_artifacts", "grader_exposure"],
          "properties": {
            "public_artifacts": {
              "type": "array",
              "items": { "type": "string", "pattern": "^[a-z0-9_]+$" }
            },
            "private_artifacts": {
              "type": "array",
              "items": { "type": "string", "pattern": "^[a-z0-9_]+$" }
            },
            "grader_exposure": { "enum": ["full_public", "summary_public", "private"] }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "prompt_file": { "type": "string", "minLength": 1 },
    "grader_file": { "type": "string", "minLength": 1 },
    "rules": {
      "type": "object",
      "required": ["general", "task_specific"],
      "properties": {
        "general": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^[a-z0-9_]+$" }
        },
        "task_specific": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^[a-z0-9_]+$" }
        }
      },
      "additionalProperties": true
    },
    "capabilities": {
      "type": "object",
      "description": "Repo-level WordPress capability taxonomy metadata from issue #15. This maps natural scenarios to benchmark capability areas without exposing hidden grader rubric.",
      "required": ["schema_version", "primary", "criteria"],
      "properties": {
        "schema_version": { "const": 1 },
        "primary": {
          "enum": [
            "ai_features",
            "agent_tooling_automation_surfaces",
            "custom_admin_ui",
            "data_interaction_apis",
            "cli_operational_tooling",
            "theme_site_building",
            "gutenberg_blocks",
            "plugin_quality_wordpress_standards"
          ]
        },
        "secondary": {
          "type": "array",
          "items": {
            "enum": [
              "ai_features",
              "agent_tooling_automation_surfaces",
              "custom_admin_ui",
              "data_interaction_apis",
              "cli_operational_tooling",
              "theme_site_building",
              "gutenberg_blocks",
              "plugin_quality_wordpress_standards"
            ]
          },
          "uniqueItems": true
        },
        "criteria": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "uniqueItems": true
        }
      },
      "additionalProperties": true
    },
    "api_provenance": {
      "type": "object",
      "description": "Optional source and freshness metadata for WordPress API curriculum scenarios.",
      "required": ["capability_area", "api_surface", "source_inputs", "freshness", "curriculum"],
      "properties": {
        "capability_area": {
          "enum": [
            "ai_features",
            "agent_tooling_automation_surfaces",
            "custom_admin_ui",
            "data_interaction_apis",
            "cli_operational_tooling",
            "theme_site_building",
            "gutenberg_blocks",
            "plugin_quality_wordpress_standards"
          ]
        },
        "api_surface": { "type": "string", "minLength": 1 },
        "source_inputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "type", "url", "ref", "checked_at", "evidence"],
            "properties": {
              "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
              "type": {
                "enum": [
                  "wordpress_core_source",
                  "gutenberg_source",
                  "wp_cli_source",
                  "developer_docs",
                  "canonical_plugin_source",
                  "modern_api_repository"
                ]
              },
              "url": { "type": "string", "minLength": 1 },
              "ref": { "type": "string", "minLength": 1 },
              "checked_at": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
              "evidence": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": true
          }
        },
        "freshness": {
          "type": "object",
          "required": ["status", "last_reviewed", "next_review_due", "cadence_days"],
          "properties": {
            "status": { "enum": ["fresh", "watch", "stale", "retired"] },
            "last_reviewed": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
            "next_review_due": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
            "cadence_days": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": true
        },
        "curriculum": {
          "type": "object",
          "required": ["lifecycle_status", "candidate_from_source_change", "promotion_next_step"],
          "properties": {
            "lifecycle_status": { "enum": ["proposed", "pilot", "calibrating", "benchmark_ready", "retired"] },
            "candidate_from_source_change": { "type": "string", "minLength": 1 },
            "promotion_next_step": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "environment": {
      "type": "object",
      "required": [
        "action_mode",
        "uses_workspace",
        "reset_fixture",
        "observation_channels",
        "allowed_tools",
        "writable_roots",
        "hidden_paths",
        "workspace_template",
        "completion_policy",
        "termination_policy",
        "truncation_policy"
      ],
      "properties": {
        "action_mode": { "enum": ["wordpress", "workspace"] },
        "uses_workspace": { "type": "boolean" },
        "reset_fixture": { "type": "string", "minLength": 1 },
        "observation_channels": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^[a-z0-9_]+$" }
        },
        "allowed_tools": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9_]+$" }
        },
        "writable_roots": { "type": "array", "items": { "type": "string" } },
        "hidden_paths": { "type": "array", "items": { "type": "string" } },
        "workspace_template": { "type": ["string", "null"] },
        "completion_policy": {
          "type": "object",
          "required": ["type"],
          "properties": { "type": { "type": "string", "minLength": 1 } },
          "additionalProperties": true
        },
        "termination_policy": {
          "type": "object",
          "required": ["type"],
          "properties": { "type": { "type": "string", "minLength": 1 } },
          "additionalProperties": true
        },
        "truncation_policy": {
          "type": "object",
          "required": ["type", "max_turns", "step_budget", "time_budget_ms"],
          "properties": {
            "type": { "type": "string", "minLength": 1 },
            "max_turns": { "type": "integer", "minimum": 1 },
            "step_budget": { "type": "integer", "minimum": 1 },
            "time_budget_ms": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "reward_spec": {
      "type": "object",
      "required": ["type", "success_threshold", "reward_range"],
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "success_threshold": { "type": "number", "minimum": 0 },
        "reward_range": {
          "type": "array",
          "prefixItems": [{ "type": "number" }, { "type": "number" }],
          "minItems": 2,
          "maxItems": 2
        }
      },
      "additionalProperties": true
    },
    "calibration": {
      "type": "object",
      "required": [
        "status",
        "benchmark_scope",
        "difficulty_band",
        "headline_score_eligible",
        "baseline_result_sets",
        "known_shortcuts",
        "task_contract_level",
        "benchmark_blockers"
      ],
      "properties": {
        "status": { "enum": ["demo", "pilot", "calibrating", "benchmark_ready", "deprecated", "retired", "excluded"] },
        "benchmark_scope": { "enum": ["demo", "pilot", "calibration", "benchmark", "excluded"] },
        "difficulty_band": { "enum": ["uncalibrated", "smoke", "easy", "medium", "hard"] },
        "headline_score_eligible": { "type": "boolean" },
        "baseline_result_sets": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "calibration_result_sets": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "pass_rate_band": {
          "enum": ["uncalibrated", "too_easy", "easy", "target", "hard", "too_hard"]
        },
        "confidence_interval_95": {
          "type": "array",
          "prefixItems": [
            { "type": "number", "minimum": 0, "maximum": 1 },
            { "type": "number", "minimum": 0, "maximum": 1 }
          ],
          "minItems": 2,
          "maxItems": 2
        },
        "held_out_private_variants_ready": { "type": "boolean" },
        "known_shortcuts": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9_]+$" }
        },
        "task_contract_level": {
          "enum": ["wordpress_state_diagnostic", "workspace_diff_diagnostic", "benchmark_replay"]
        },
        "benchmark_blockers": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9_]+$" }
        },
        "benchmark_metadata": {
          "type": "object",
          "description": "Version and compatibility identity used when a scenario is promoted into benchmark comparison.",
          "required": ["benchmark_version", "compatibility_group"],
          "properties": {
            "benchmark_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[a-z0-9][a-z0-9.-]*)?$" },
            "compatibility_group": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
            "compatible_with": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "version_identity": {
              "type": "object",
              "required": [
                "manifest_sha256",
                "prompt_sha256",
                "grader_sha256",
                "setup_sha256",
                "expected_artifacts_sha256",
                "replay_contract_sha256"
              ],
              "properties": {
                "manifest_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
                "prompt_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
                "grader_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
                "setup_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
                "expected_artifacts_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
                "replay_contract_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "reward_soundness_review": {
          "type": "object",
          "description": "Human/reference-oracle review evidence that representative pass and adversarial outputs match expected WordPress quality before benchmark promotion.",
          "required": [
            "status",
            "reviewed_at",
            "reviewer_type",
            "artifact",
            "classification",
            "shortcut_resolution_status",
            "representative_passed_outputs",
            "adversarial_or_failed_outputs",
            "diagnostic_contract_review"
          ],
          "properties": {
            "status": { "enum": ["reviewed", "needs_review"] },
            "reviewed_at": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
            "reviewer_type": { "enum": ["human", "reference_oracle"] },
            "artifact": { "type": "string", "minLength": 1 },
            "classification": { "type": "string", "minLength": 1 },
            "shortcut_resolution_status": { "enum": ["resolved", "unresolved", "not_applicable"] },
            "representative_passed_outputs": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" }
            },
            "adversarial_or_failed_outputs": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" }
            },
            "diagnostic_contract_review": {
              "type": "object",
              "required": ["status", "classification"],
              "properties": {
                "status": { "enum": ["reviewed", "not_applicable"] },
                "classification": { "type": "string", "minLength": 1 },
                "promotion_blocker": { "type": "string", "pattern": "^[a-z0-9_]+$" }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "expected_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z0-9_]+$" },
      "uniqueItems": true
    },
    "episode_contract": {
      "type": "object",
      "description": "Canonical episode contract metadata for runners that emit traces.",
      "required": ["schema_version", "allowed_action_types", "max_steps", "setup", "success_checks"],
      "properties": {
        "schema_version": { "const": 1 },
        "allowed_action_types": {
          "type": "array",
          "minItems": 1,
          "items": { "enum": ["wp_cli", "filesystem", "rest", "browser"] },
          "uniqueItems": true
        },
        "max_steps": { "type": "integer", "minimum": 1 },
        "setup": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "success_checks": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "uniqueItems": true
        }
      },
      "additionalProperties": true
    },
    "probes": {
      "type": "object",
      "description": "Optional zero-weight behavioral telemetry probes. Probes are diagnostics and must not affect reward unless promoted into explicit grader policy.",
      "properties": {
        "behavioral_fingerprints": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "type", "reward_weight", "description", "dimensions"],
            "properties": {
              "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
              "type": { "enum": ["rendered_site_design"] },
              "reward_weight": { "const": 0 },
              "description": { "type": "string", "minLength": 1 },
              "dimensions": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "pattern": "^[a-z0-9_]+$" },
                "uniqueItems": true
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "calibration": {
            "properties": {
              "task_contract_level": { "const": "benchmark_replay" }
            },
            "required": ["task_contract_level"]
          }
        },
        "required": ["calibration"]
      },
      "then": {
        "properties": {
          "expected_artifacts": {
            "allOf": [
              { "contains": { "const": "grader_result" } },
              { "contains": { "const": "replay_bundle" } },
              { "contains": { "const": "replay_trace" } },
              {
                "contains": {
                  "enum": ["wordpress_state", "workspace_diff", "plugin_files", "media_library"]
                }
              }
            ]
          },
          "episode_contract": {
            "properties": {
              "allowed_action_types": {
                "items": { "enum": ["wp_cli", "filesystem"] }
              }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": true
}
