{
  "id": "wp-gym",
  "name": "wp-gym",
  "extensions": {
    "wordpress": {
      "settings": {
        "playground_wordpress_version": "6.9",
        "playground_blueprint": {
          "$schema": "https://playground.wordpress.net/blueprint-schema.json",
          "preferredVersions": {
            "php": "8.3",
            "wp": "latest"
          }
        },
        "playground_scenario_manifests": [
          "scenarios/block-markup/valid-semantic-blocks.json",
          "scenarios/block-markup/nested-layout-blocks.json",
          "scenarios/block-markup/no-fallback-pricing-section.json",
          "scenarios/site-building/community-garden.json",
          "scenarios/visual-builder/elementor-hero-refresh.json",
          "scenarios/content-migration/media-attachment-import.json",
          "scenarios/site-understanding/service-relationship-map.json",
          "scenarios/modern-wordpress-api/abilities-site-summary.json",
          "scenarios/modern-wordpress-api/rest-route-status.json",
          "scenarios/wordpress-investigation/homepage-source-diagnosis.json"
        ],
        "playground_workloads": [
          {
            "id": "smoke-homepage",
            "label": "Smoke homepage task wiring",
            "run": [
              {
                "type": "php",
                "file": "tasks/smoke-homepage/setup.php"
              },
              {
                "type": "php",
                "file": "checks/smoke-homepage.php"
              }
            ],
            "metadata": {
              "task_manifest": "tasks/smoke-homepage/manifest.json",
              "prompt": "prompts/smoke-homepage.md",
              "blueprint": "blueprints/smoke-homepage.json"
            }
          }
        ],
        "bench_warmup_iterations": 0
      }
    }
  },
  "self_checks": {
    "lint": [
      "node --check scripts/validate-scenarios.mjs",
      "jq empty homeboy.json tasks/smoke-homepage/manifest.json blueprints/smoke-homepage.json bundle-validator.json bundles/datamachine-task-runner/manifest.json bundles/datamachine-task-runner/flows/wordpress-task-runner-flow.json bundles/datamachine-task-runner/pipelines/wordpress-task-runner-pipeline.json task-sets/first-live-run.json task-sets/benchmark-readiness-pilot.json task-sets/visual-builder.json task-sets/wordpress-investigation.json scenarios/wordpress-investigation/homepage-source-diagnosis.json scenarios/content-migration/media-attachment-import.json scenarios/site-understanding/service-relationship-map.json fixtures/benchmark-policy/pilot-task-set-envelope.json fixtures/benchmark-policy/benchmark-ready-envelope.json starter-workspaces/content-migration-media-import/import-package/content-export.json"
    ],
    "test": [
      "npm test"
    ]
  }
}
